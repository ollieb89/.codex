2026-02-24T12:00:00.068213Z  INFO session_loop{thread_id=019c8f81-0495-7dd2-91ad-0f589dfd937e}: codex_core::stream_events_utils: ToolCall: exec_command {"cmd":"python - <<'PY'\nimport re, os, textwrap\nfrom pathlib import Path\n\nroot = Path('/home/ollie/.codex/commands')\nmd_files = sorted(root.glob('gsd-*.md'))\n\ndef title_from_description(desc: str) -> str:\n    if not desc:\n        return ''\n    # Capitalize first letter, keep rest as-is\n    return desc[0].upper() + desc[1:]\n\ndef parse_frontmatter(text: str):\n    fm = {}\n    tools = []\n    if not text.startswith('---'):\n        return fm, tools, text\n    parts = text.split('---', 2)\n    if len(parts) < 3:\n        return fm, tools, text\n    fm_text = parts[1]\n    body = parts[2].lstrip('\\n')\n    # Simple parse\n    lines = fm_text.splitlines()\n    i = 0\n    while i < len(lines):\n        line = lines[i].rstrip()\n        if not line:\n            i += 1\n            continue\n        if line.startswith('tools:'):\n            i += 1\n            while i < len(lines):\n                sub = lines[i]\n                if not sub.startswith('  '):\n                    break\n                m = re.match(r\"\\s{2}([a-zA-Z0-9_-]+):\\s*(true|false)\", sub.strip())\n                if m and m.group(2) == 'true':\n                    tools.append(m.group(1))\n                i += 1\n            continue\n        m = re.match(r\"([a-zA-Z0-9_-]+):\\s*(.*)\", line)\n        if m:\n            fm[m.group(1)] = m.group(2).strip().strip('\"')\n        i += 1\n    return fm, tools, body\n\ndef replace_tag_lines(body: str):\n    def titleize(tag: str):\n        return ' '.join([w.capitalize() for w in tag.replace('_',' ').split()])\n\n    out_lines = []\n    for line in body.splitlines():\n        m_open = re.match(r\"^\\s*<([a-zA-Z0-9_\\-]+)>\\s*$\", line)\n        m_close = re.match(r\"^\\s*</([a-zA-Z0-9_\\-]+)>\\s*$\", line)\n        if m_open:\n            tag = m_open.group(1)\n            out_lines.append(f\"## {titleize(tag)}\")\n            continue\n        if m_close:\n            continue\n        out_lines.append(line)\n    return '\\n'.join(out_lines).strip() + '\\n'\n\nfor md_path in md_files:\n    text = md_path.read_text()\n    fm, tools, body = parse_frontmatter(text)\n    desc = fm.get('description','').strip()\n    arg_hint = fm.get('argument-hint','').strip()\n    stem = md_path.stem\n    title = title_from_description(desc) if desc else stem\n\n    body_md = replace_tag_lines(body)\n\n    inputs_lines = []\n    if arg_hint:\n        inputs_lines.append(f\"- `$ARGUMENTS`: {arg_hint}\")\n    else:\n        inputs_lines.append(\"- `$ARGUMENTS`: (none)\")\n\n    tools_lines = []\n    if tools:\n        tools_lines = [f\"- `{t}`\" for t in tools]\n    else:\n        tools_lines = [\"- (none)\"]\n\n    header_tools = ''\n    if tools:\n        header_tools = f\"tools: [{', '.join(tools)}]\"\n\n    header = \"---\\n\" + \"\\n\".join([\n        f\"name: {stem}\",\n        \"category: gsd\",\n        \"complexity: standard\",\n        header_tools\n    ]).strip() + \"\\n---\\n\\n\"\n\n    prompt_parts = [\n        header,\n        f\"# /{stem} - {title}\\n\",\n        \"## Inputs\\n\" + \"\\n\".join(inputs_lines) + \"\\n\",\n        \"## Tools\\n\" + \"\\n\".join(tools_lines) + \"\\n\",\n        body_md\n    ]\n\n    prompt = \"\\n\".join([p for p in prompt_parts if p.strip()])\n\n    toml = f\"description = \\\"{desc}\\\"\\n\\nprompt = \\\"\\\"\\\"\\n{prompt}\\n\\\"\\\"\\\"\\n\"\n    toml_path = root / f\"{stem}.toml\"\n    toml_path.write_text(toml)\n\nprint(f\"Converted {len(md_files)} files.\")\nPY"} thread_id=019c8f81-0495-7dd2-91ad-0f589dfd937e
