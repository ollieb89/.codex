ious)) {\n        const message = readStatusMessage(connector);\n        if (connector.status === 'connected') {\n          toast.success(message);\n        } else {\n          toast.error(message);\n        }\n      }\n\n      seen.current[connector.id] = connector.status;\n    });\n  }, [connectors]);\n\n  return null;\n}\nEOF","workdir":"/home/ollie/.openclaw/workspace/occc"} thread_id=019c8ffa-1334-73d2-8e7a-58de3d96a71b
