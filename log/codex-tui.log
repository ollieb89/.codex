+    <title>Add Privacy Center, inline badges, filterable audit log, and explicit deny-path local-only message</title>
+    <requirements>PRIV-02</requirements>
+    <depends_on>P01-01-T01</depends_on>
+    <files>
+      <file>src/lib/privacy/audit-log.ts</file>
